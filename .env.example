DATABASE_URI=postgresql://payload:payload_dev@127.0.0.1:5433/ic_yec
PAYLOAD_SECRET=your-secret-here
# Must match the domain the site/admin is served from (e.g. https://ic-yec.com).
# If this is stale, media URLs break and the admin gets 403 on every request.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Extra origins allowed to make authenticated API requests (comma-separated).
# Anything not listed here (nor in NEXT_PUBLIC_SERVER_URL) is rejected by the
# CSRF check. Useful for the www. host and the old *.vercel.app domain.
# ALLOWED_ORIGINS=https://www.ic-yec.com,https://ic-yec-website.vercel.app

UPLOADTHING_TOKEN=your-uploadthing-token

# Email — production (Gmail SMTP)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=IC-YEC <your-gmail@gmail.com>

# Google OAuth — for Google Meet / Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
